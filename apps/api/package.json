{
  "name": "@verttex/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsup",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "typecheck": "tsc --noEmit"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.787.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.2",
    "@fastify/jwt": "^9.0.4",
    "@fastify/swagger": "^9.4.2",
    "@fastify/swagger-ui": "^5.2.1",
    "@prisma/client": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "pg": "^8.13.1",
    "@verttex/auth": "workspace:*",
    "@verttex/env": "workspace:*",
    "@verttex/types": "workspace:*",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "fastify-type-provider-zod": "^4.0.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@verttex/eslint-config": "workspace:*",
    "@verttex/tsconfig": "workspace:*",
    "@types/node": "^22.10.7",
    "@types/pg": "^8.11.10",
    "prisma": "^7.8.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2"
  },
  "eslintConfig": {
    "extends": [
      "@verttex/eslint-config/node.js"
    ]
  }
}
